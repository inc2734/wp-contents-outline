{
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"volta": {
		"node": "24.14.1"
	},
	"author": "inc2734",
	"license": "GPL-2.0+",
	"dependencies": {},
	"devDependencies": {
		"@inc2734/contents-outline": "0.1.8",
		"@wordpress/browserslist-config": "^6.44.0",
		"@wordpress/scripts": "^32.0.0",
		"@wordpress/env": "^11.4.0",
		"cpy-cli": "^7.0.0",
		"npm-run-all": "^4.1.5",
		"rimraf": "^6.1.3"
	},
	"scripts": {
		"wp-env": "wp-env",
		"start": "wp-env start",
		"stop": "wp-env stop",
		"destroy": "wp-env destroy && wp-env destroy --config=.wp-env.tests.json",
		"cli": "wp-env run cli",
		"wp": "wp-env run cli --env-cwd=\"wp-content/plugins/wp-contents-outline\" wp",
		"composer": "wp-env run cli --env-cwd=\"wp-content/plugins/wp-contents-outline\" composer",
		"test-composer": "wp-env run cli --config=.wp-env.tests.json --env-cwd=\"wp-content/plugins/wp-contents-outline\" composer",
		"test:php:start": "wp-env start --config=.wp-env.tests.json",
		"pretest:php:lint": "npm run test:php:start && npm run test-composer install -- --no-interaction",
		"test:php:lint": "npm run test:php:start && npm run test-composer lint",
		"posttest:php:lint": "wp-env stop --config=.wp-env.tests.json",
		"pretest:php:unit": "npm run test:php:start && npm run test-composer install -- --no-interaction",
		"test:php:unit": "npm run test:php:start && wp-env run --config=.wp-env.tests.json --env-cwd=\"wp-content/plugins/wp-contents-outline\" wordpress vendor/bin/phpunit -c .phpunit.xml.dist --verbose",
		"posttest:php:unit": "wp-env stop --config=.wp-env.tests.json",
		"test:php": "run-s test:php:*",
		"test": "run-s test:*",
		"clean:js": "rimraf src/assets/js",
		"clean:packages": "rimraf src/assets/packages",
		"packages:@inc2734/contents-outline": "cpy './node_modules/@inc2734/**' './src/assets/packages/@inc2734'",
		"packages": "npm run clean:packages && npm-run-all -p packages:*",
		"js:app": "wp-scripts build src/src/js/app.js --output-path src/assets/js",
		"js": "npm run clean:js && npm-run-all -p js:*",
		"build": "npm run js && npm run packages"
	}
}
